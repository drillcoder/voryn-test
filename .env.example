CONFIRMATIONS=0
HEAD_DELAY_MS=1000
HEAD_DEPTH_BLOCKS=10000

FETCH_DELAY_MS=100
FETCH_BATCH_SIZE=10
FETCH_CLAIM_TTL_MS=125000
RETRY_MAX_ATTEMPTS=10
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=10000

SEQUENCER_DELAY_MS=100
SEQUENCER_MAX_BLOCKS_PER_TICK=10

RETENTION_DELAY_MS=60000
RETENTION_DEPTH_BLOCKS=10000

GRAFANA_CLOUD_PROM_REMOTE_WRITE_URL=https://prometheus-prod-xx-prod-xxx.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USERNAME=your-prometheus-instance-id
GRAFANA_CLOUD_API_TOKEN=your-grafana-cloud-access-policy-token
